{
	"name": "junior-sensei-guide",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"dev:backend": "node services/pocketbase/runPocketbase.mjs",
		"dev:web": "next dev -p 3001 --turbopack",
		"dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
		"lint": "eslint",
		"typegen": "npx pocketbase-typegen --db ./services/pocketbase/pb_data/data.db --out lib/pocketbase-types.ts",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"dotenv": "^17.3.1",
		"lucide-react": "^0.577.0",
		"next": "16.1.6",
		"pocketbase": "^0.26.8",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-hook-form": "^7.71.2",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"jsdom": "^29.0.1",
		"pocketbase-typegen": "^1.3.3",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vitest": "^4.1.0"
	}
}
